{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-agents-clubhouse",
  "name": {
    "en": "Agents Clubhouse",
    "ko": "에이전트 클럽하우스"
  },
  "version": "0.1.0",
  "repo": "https://github.com/soksak-ai/soksak-plugin-agents-clubhouse.git",
  "description": {
    "en": "A hub that brings multiple AI coding agents (Claude, Codex, Gemini) together in one workspace — select 1–3 via checkboxes, discuss in turn-based, free, or simultaneous mode, and mention a peer directly with '@name'. Conversation by default; the agents touch real files only when you ask. Runs agents through the agents-acp runtime.",
    "ko": "여러 AI 코딩 에이전트(Claude·Codex·Gemini)를 한 워크스페이스에 모아주는 허브 — 체크박스로 1~3 선택, 탭 순서대로 턴제·자유·동시 모드로 함께 논의. 본문 '@이름' 으로 동료 직접 호출. 기본은 대화이고, 사용자가 요청할 때만 실파일 작업. 에이전트 실행은 agents-acp 런타임 경유."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "ui:titlebar",
    "commands",
    "commands:inject",
    "programs",
    "fs:read"
  ],
  "dependencies": {
    "soksak-plugin-agents-acp": "^0.1.0"
  },
  "configuration": [
    {
      "key": "permissionPolicy",
      "type": "enum",
      "enum": [
        "deny",
        "allow",
        "ask"
      ],
      "enumLabels": [
        "거부(안전)",
        "허용",
        "물어보기"
      ],
      "default": "deny",
      "title": "권한 요청 정책",
      "description": "에이전트가 파일/명령 권한을 요청할 때 처리 방식"
    },
    {
      "key": "kibitzDefault",
      "type": "enum",
      "enum": [
        "facil",
        "turn",
        "simul"
      ],
      "enumLabels": [
        "진행(사회자)",
        "순차",
        "동시"
      ],
      "default": "facil",
      "title": "대화 기본 모드",
      "description": "새 워크스페이스의 대화 스타일 기본값 — 진행(진행자가 동료를 조율·마무리), 순차(탭 순서 각 1회), 동시(전원 병렬 발화)"
    },
    {
      "key": "facilMaxRounds",
      "type": "number",
      "default": 6,
      "min": 1,
      "max": 20,
      "title": "진행 모드 라운드 상한",
      "description": "진행 모드에서 진행자↔동료 라운드의 하드 상한(폭주 방지 — 도달 시 강제 마무리)"
    },
    {
      "key": "nameTriggerDepthCap",
      "type": "number",
      "default": 4,
      "min": 1,
      "max": 20,
      "title": "@멘션 연쇄 상한",
      "description": "한 @지목 스레드가 이어지는 최대 깊이(폭주 방지 안전판 — 강제 아님)"
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "clubhouse",
        "title": {
          "en": "Clubhouse",
          "ko": "Clubhouse"
        },
        "icon": "💬",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content"
      }
    ],
    "commands": [
      {
        "name": "send",
        "title": {
          "en": "Send Message to Clubhouse",
          "ko": "활성 Clubhouse 에 사람 메시지 전송(라이브 구동·자동화)"
        }
      },
      {
        "name": "state",
        "title": {
          "en": "Clubhouse Live State",
          "ko": "활성 Clubhouse 라이브 상태(스트리밍 길이 등 — 관찰·E2E)"
        }
      },
      {
        "name": "ask",
        "title": {
          "en": "Ask (single agent, headless)",
          "ko": "프롬프트 1회(단일 에이전트, 헤드리스)"
        }
      },
      {
        "name": "converse",
        "title": {
          "en": "Converse (multi-agent, headless)",
          "ko": "다중 에이전트 1교환(턴테이킹, 헤드리스 E2E)"
        }
      },
      {
        "name": "tower.plan",
        "title": {
          "en": "Tower Plan (slow-path, headless)",
          "ko": "컨트롤 타워 계획(slow-path NL→3축 plan, dry-run/commit)"
        }
      }
    ],
    "nodes": [
      {
        "id": "send",
        "description": "전송 버튼"
      },
      {
        "id": "input",
        "description": "메시지 입력"
      },
      {
        "id": "tab",
        "description": "에이전트 탭(체크·드래그)"
      },
      {
        "id": "mode",
        "description": "대화 모드 버튼(진행/순차/동시)"
      },
      {
        "id": "crown",
        "description": "진행자 지정(👑, 진행 모드)"
      },
      {
        "id": "modal",
        "description": "참견 모달 버튼(지금 끊기/끝나면/취소)"
      },
      {
        "id": "tower",
        "description": "AI-명령 컨트롤 타워 모달(NL 입력바·예시행·명령 팔레트·검색·라이브칸·닫기·드래그 그립)"
      }
    ],
    "programs": [
      {
        "id": "clubhouse",
        "title": {
          "en": "Clubhouse",
          "ko": "Clubhouse"
        },
        "path": {
          "ko": "에이전트",
          "en": "Agents"
        },
        "kind": "view",
        "view": "clubhouse"
      }
    ]
  }
}
